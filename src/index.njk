---
layout: layouts/base.njk
title: Gradient Archive
---

{# Collect all unique tags from the gradients collection #}
{% set allTags = collections.gradients | allTags %}

{# ── Tag filter bar ── #}
<nav class="tag-bar" id="tagBar" aria-label="Filter by tag">
  <button class="tag-btn active" data-tag="all">All</button>
  {% for tag in allTags %}
    <button class="tag-btn" data-tag="{{ tag }}">{{ tag }}</button>
  {% endfor %}
</nav>

{# ── Gallery grid ── #}
<div class="gallery-grid" id="galleryGrid" aria-label="Gradient gallery">

  {% for gradient in collections.gradients %}
    <a
      class="card"
      href="{{ gradient.url | url }}"
      data-tags="{{ gradient.data.tags | jsonify }}"
      style="animation-delay: {{ loop.index0 * 55 }}ms"
      aria-label="View {{ gradient.data.title }}"
    >
      <div class="card-thumb-wrap">
        <div class="card-skeleton" aria-hidden="true"></div>
        <img
          class="card-thumb"
          src="{{ '/images/thumbs/' | url }}{{ gradient.data.thumb or gradient.data.full }}"
          alt="{{ gradient.data.title }}"
          loading="lazy"
          decoding="async"
        />
      </div>
      <div class="card-footer">
        <span class="card-name">{{ gradient.data.title }}</span>
        <span class="card-tags-inline">
          {% for tag in gradient.data.tags %}
            <span class="card-tag">{{ tag }}</span>
          {% endfor %}
        </span>
      </div>
    </a>
  {% endfor %}

</div>
