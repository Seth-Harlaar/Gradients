<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title or "Gradient Archive" }}{% if title %} — Gradient Archive{% endif %}</title>
  <meta name="description" content="{{ description or 'A curated collection of gradient imagery.' }}" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=DM+Mono:wght@300;400&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="{{ '/css/style.css' | url }}" />
  {% block head %}{% endblock %}
</head>
<body class="{{ bodyClass or '' }}">

  <header class="site-header">
    <div class="header-inner">
      <a href="{{ '/' | url }}" class="site-title-link">
        <span class="site-title">Gradients</span>
      </a>
    </div>
  </header>

  <main>
    {{ content | safe }}
  </main>

  {% block scripts %}
    <script src="{{ '/js/gallery.js' | url }}"></script>
  {% endblock %}

</body>
</html>
