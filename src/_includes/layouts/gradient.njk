---
layout: layouts/base.njk
---

<article class="gradient-page">

  {# ── Hero image ── #}
  <div class="gradient-hero">
    <img
      class="gradient-hero-img"
      src="/images/full/{{ thumb or full }}"
      alt="{{ title }}"
    />
    <div class="gradient-hero-overlay">
      <a href="/" class="back-link">← All gradients</a>
      <div class="gradient-hero-meta">
        <h1 class="gradient-title">{{ title }}</h1>
        {% if tags %}
          <div class="gradient-tags">
            {% for tag in tags %}
              <a class="tag-pill" href="/?tag={{ tag }}">{{ tag }}</a>
            {% endfor %}
          </div>
        {% endif %}
      </div>
    </div>
  </div>

  {# ── Download bar ── #}
  <div class="gradient-toolbar">
    <div class="toolbar-inner">
      <div class="toolbar-meta">
        {% if date %}
          <span class="toolbar-date">{{ date | dateFormat }}</span>
        {% endif %}
        {% if dimensions %}
          <span class="toolbar-dim">{{ dimensions }}</span>
        {% endif %}
      </div>
      <div class="toolbar-actions">
        {% if full %}
          <a class="btn-download" href="/images/full/{{ full }}" download="{{ title }}">
            ↓ Download full resolution
          </a>
        {% endif %}
      </div>
    </div>
  </div>

  {# ── Body content — write whatever you want in the .md file ── #}
  {% if content | trim | length > 0 %}
    <div class="gradient-body">
      {{ content | safe }}
    </div>
  {% endif %}

  {# ── Prev / Next navigation ── #}
  {% set allGradients = collections.gradients %}
  {% set currentIndex = -1 %}
  {% for g in allGradients %}
    {% if g.url == page.url %}{% set currentIndex = loop.index0 %}{% endif %}
  {% endfor %}

  {% if allGradients.length > 1 %}
    <nav class="gradient-nav">
      {% if currentIndex > 0 %}
        {% set prev = allGradients[currentIndex - 1] %}
        <a class="gnav-item gnav-prev" href="{{ prev.url }}">
          <span class="gnav-label">← Previous</span>
          <img class="gnav-thumb" src="/images/thumbs/{{ prev.data.thumb or prev.data.full }}" alt="{{ prev.data.title }}" loading="lazy" />
          <span class="gnav-title">{{ prev.data.title }}</span>
        </a>
      {% else %}
        <div></div>
      {% endif %}

      {% if currentIndex < allGradients.length - 1 %}
        {% set next = allGradients[currentIndex + 1] %}
        <a class="gnav-item gnav-next" href="{{ next.url }}">
          <span class="gnav-label">Next →</span>
          <img class="gnav-thumb" src="/images/thumbs/{{ next.data.thumb or next.data.full }}" alt="{{ next.data.title }}" loading="lazy" />
          <span class="gnav-title">{{ next.data.title }}</span>
        </a>
      {% endif %}
    </nav>
  {% endif %}

</article>
